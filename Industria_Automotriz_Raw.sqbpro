able schema="main" name="ventas_hibridos" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="87"/><column index="2" value="300"/><column index="3" value="75"/><column index="4" value="39"/><column index="5" value="51"/><column index="6" value="77"/><column index="7" value="255"/><column index="8" value="76"/><column index="9" value="140"/><column index="10" value="92"/><column index="11" value="151"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="ventas_todo_tipo" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="300"/><column index="2" value="87"/><column index="3" value="300"/><column index="4" value="75"/><column index="5" value="39"/><column index="6" value="51"/><column index="7" value="119"/><column index="8" value="300"/><column index="9" value="135"/><column index="10" value="103"/><column index="11" value="79"/><column index="12" value="104"/><column index="13" value="119"/><column index="14" value="56"/><column index="15" value="151"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 6*">-- ==============================================================================
-- CREACIÓN DE LA TABLA FINAL: EXPORTACIONES
-- ==============================================================================
DROP TABLE IF EXISTS &quot;0_0_Historico_Exportaciones_V3&quot;;

CREATE TABLE &quot;0_0_Historico_Exportaciones_V3&quot; AS
SELECT 
    -- 1. La Llave Maestra (Código de barras para cruzar con Dim_Vehiculos)
    UPPER(MARCA || '-' || MODELO || '-' || TIPO || '-' || SEGMENTO) AS ID_Vehiculo,
    
    -- 2. La Fecha Oficial (Formato YYYY-MM-DD para Power BI)
    printf('%04d-%02d-01', ANIO, ID_MES) AS Fecha,
    
    -- 3. Traemos el resto de tu información limpia
    PROD_EST,
    COBERTURA,
    ANIO,
    ID_MES,
    MARCA,
    MODELO,
    TIPO,
    SEGMENTO,
    ID_PAIS_DESTINO,
    Pais,
    UNI_VEH,
    ESTATUS
FROM &quot;0_0_Historico_Exportaciones_V2&quot;;</sql><sql name="SQL 7*">-- ==============================================================================
-- CREACIÓN DE LA TABLA FINAL: VENTAS HÍBRIDOS
-- ==============================================================================
DROP TABLE IF EXISTS &quot;1_0_Historico_Ventas_Hibridos_V3&quot;;

CREATE TABLE &quot;1_0_Historico_Ventas_Hibridos_V3&quot; AS
SELECT 
    -- 1. La Fecha Oficial (Formato YYYY-MM-DD para Power BI)
    printf('%04d-%02d-01', ANIO, ID_MES) AS Fecha,
    
    -- 2. Traemos el resto de la información limpia
    PROD_EST,
    COBERTURA,
    ANIO,
    ID_MES,
    ID_ENTIDAD,
    Entidad,
    VEH_ELECTR,
    VEH_HIBRIDAS_PLUGIN,
    VEH_HIBRIDAS,
    ESTATUS
FROM &quot;1_0_Historico_Ventas_Hibridos_V2&quot;;</sql><sql name="SQL 8*">-- ==============================================================================
-- CREACIÓN DE LA TABLA FINAL: PRODUCCIÓN
-- ==============================================================================
DROP TABLE IF EXISTS &quot;2_0_Historico_Produccion_V3&quot;;

CREATE TABLE &quot;2_0_Historico_Produccion_V3&quot; AS
SELECT 
    -- 1. La Llave Maestra (Código de barras idéntico para conectar con Dim_Vehiculos)
    UPPER(MARCA || '-' || MODELO || '-' || TIPO || '-' || SEGMENTO) AS ID_Vehiculo,
    
    -- 2. La Fecha Oficial (Formato YYYY-MM-DD para Power BI)
    printf('%04d-%02d-01', ANIO, ID_MES) AS Fecha,
    
    -- 3. Traemos el resto de tu información limpia
    PROD_EST,
    COBERTURA,
    ANIO,
    ID_MES,
    MARCA,
    MODELO,
    TIPO,
    SEGMENTO,
    UNI_VEH,
    ESTATUS
FROM &quot;2_0_Historico_Produccion_V2&quot;;</sql><sql name="SQL 9*">-- ==============================================================================
-- CREACIÓN DE LA TABLA FINAL: VENTAS TODO TIPO
-- ==============================================================================
DROP TABLE IF EXISTS &quot;3_0_Ventas_V3&quot;;

CREATE TABLE &quot;3_0_Ventas_V3&quot; AS
SELECT 
    -- 1. La Llave Maestra (Código de barras para cruzar con Dim_Vehiculos)
    UPPER(MARCA || '-' || MODELO || '-' || TIPO || '-' || SEGMENTO) AS ID_Vehiculo,
    
    -- 2. La Fecha Oficial (Formato YYYY-MM-DD para Power BI)
    printf('%04d-%02d-01', ANIO, ID_MES) AS Fecha,
    
    -- 3. Traemos el resto de tu información limpia
    PROD_EST,
    COBERTURA,
    ANIO,
    ID_MES,
    MARCA,
    MODELO,
    TIPO,
    SEGMENTO,
    ORIGEN,
    ID_PAIS_ORIGEN,
    &quot;Pais Origen&quot;,
    UNI_VEH,
    ESTATUS
FROM &quot;3_0_Historico_Ventas_Todo_Tipo_V2&quot;;</sql><current_tab id="3"/></tab_sql></sqlb_project>
